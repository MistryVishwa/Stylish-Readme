{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "^/api/marketplace\\.svg$", "dest": "/api/marketplace.svg" },
    { "src": "^/api/([\\w-]+)\\.svg$", "dest": "/api/widget?type=$1" },
    { "handle": "filesystem" },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(time|clock|timezone).svg",
      "headers": [
        { "key": "Content-Type",                "value": "image/svg+xml; charset=utf-8" },
        { "key": "Cache-Control",               "value": "public, max-age=60, s-maxage=60, stale-while-revalidate=30" },
        { "key": "Vary",                        "value": "Accept-Encoding" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/api/music.svg",
      "headers": [
        { "key": "Content-Type",                "value": "image/svg+xml; charset=utf-8" },
        { "key": "Cache-Control",               "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=120" },
        { "key": "Vary",                        "value": "Accept-Encoding" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/api/(date|quote|streak|profile|marketplace|countdown).svg",
      "headers": [
        { "key": "Content-Type",                "value": "image/svg+xml; charset=utf-8" },
        { "key": "Cache-Control",               "value": "public, max-age=3600, s-maxage=3600, stale-while-revalidate=600" },
        { "key": "Vary",                        "value": "Accept-Encoding" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/api/flag.svg",
      "headers": [
        { "key": "Content-Type",                "value": "image/svg+xml; charset=utf-8" },
        { "key": "Cache-Control",               "value": "public, max-age=86400, s-maxage=86400, stale-while-revalidate=3600" },
        { "key": "Vary",                        "value": "Accept-Encoding" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}