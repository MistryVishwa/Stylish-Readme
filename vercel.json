{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,

  "routes": [
    { "src": "^/api/([\\w-]+)\\.svg$", "dest": "/api/widget?type=$1" },
    { "handle": "filesystem" },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ],

  "headers": [
    {
      "source": "/api/:type.svg",
      "headers": [
        { "key": "Content-Type", "value": "image/svg+xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=60, s-maxage=60, stale-while-revalidate=120" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
